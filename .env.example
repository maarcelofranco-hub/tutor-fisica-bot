# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=sqlite:///./data/app.db

# Questions: auto | drive | local
# auto = live Google Drive when configured (recommended for Marcelo)
