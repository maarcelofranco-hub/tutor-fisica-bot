LOCAL_QUESTIONS_PATH=./data/questions_drive

# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=physics-mvp-verify-2026-himari
WHATSAPP_API_VERSION=v21.0

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CORRECTION_STYLE=detailed

# Google Drive — Marcelo folder (independent mode)
GOOGLE_DRIVE_ROOT_FOLDER_ID=1doXGbprntcbLDc28XQ7T-kImx1tc7jcd
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/google-service-account.json
# Cloud deploy: paste full service account JSON (Marcelo owns this account)
GOOGLE_SERVICE_ACCOUNT_JSON=
DRIVE_THEMES_FOLDER_NAME=Temas

# Bot messages
